    printOperand(MI, 0, O);
    break;
  case 2:
    // PseudoFLD, PseudoFLH, PseudoFLW, PseudoFSD, PseudoFSH, PseudoFSW, Pseu...
    printOperand(MI, 1, O);
    break;
  case 3:
